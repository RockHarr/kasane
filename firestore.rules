rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    // ─── Helpers ────────────────────────────────────────────────────────────

    // Solo el usuario autenticado puede acceder a sus propios datos
    function isOwner(userId) {
      return request.auth != null && request.auth.uid == userId;
    }

    // Valida estructura y rangos del perfil financiero
    function isValidProfile(data) {
      return data.keys().hasAll(['excedente', 'reserva', 'aporteMensual', 'horizonte'])
        && data.excedente is number && data.excedente > 0
        && data.reserva is number  && data.reserva >= 0
        && data.aporteMensual is number && data.aporteMensual >= 0
        && data.horizonte is number && data.horizonte >= 1 && data.horizonte <= 600;
    }

    // Valida que la asignación de portafolio sea proporcional y válida
    function isValidAllocation(data) {
      return data.keys().hasAll(['bonds', 'dividends', 'stocks'])
        && data.bonds is number    && data.bonds >= 0    && data.bonds <= 1
        && data.dividends is number && data.dividends >= 0 && data.dividends <= 1
        && data.stocks is number   && data.stocks >= 0   && data.stocks <= 1
        && (data.bonds + data.dividends + data.stocks) >= 0.99
        && (data.bonds + data.dividends + data.stocks) <= 1.01;
    }

    // Valida el perfil de onboarding
    function isValidOnboarding(data) {
      return data.keys().hasAll(['perfil', 'pais', 'aporteMensual', 'horizonte'])
        && data.perfil is string
        && data.pais is string
        && data.aporteMensual is number && data.aporteMensual > 0
        && data.horizonte is number && data.horizonte >= 1 && data.horizonte <= 600
        // genero es opcional: puede no existir, ser 'M'/'F' o null
        && (!data.keys().hasAny(['genero']) || data.genero == null || data.genero is string)
        // meta es opcional: puede no existir, ser un MetaId string o null
        && (!data.keys().hasAny(['meta']) || data.meta == null || data.meta is string);
    }

    // Valida la cuenta de trading simulado
    function isValidTradingAccount(data) {
      return data.keys().hasAll(['cashUSD', 'holdings'])
        && data.cashUSD is number && data.cashUSD >= 0
        && data.holdings is list;
    }

    // Valida una orden de trading (compra o venta)
    function isValidTradeOrder(data) {
      return data.keys().hasAll(['symbol', 'name', 'action', 'quantity', 'priceAtOrder', 'totalUSD', 'createdAt'])
        && data.symbol is string
        && data.name is string
        && (data.action == 'buy' || data.action == 'sell')
        && data.quantity is number && data.quantity > 0
        && data.priceAtOrder is number && data.priceAtOrder > 0
        && data.totalUSD is number && data.totalUSD > 0
        && data.createdAt == request.time; // debe ser serverTimestamp()
    }

    // Valida una simulación guardada (incluye resultado DCA)
    function isValidSimulation(data) {
      return data.keys().hasAll(['profile', 'allocation', 'resultado', 'createdAt'])
        && isValidProfile(data.profile)
        && isValidAllocation(data.allocation)
        && data.resultado.keys().hasAll(['valorFinal', 'totalAportado', 'ganancia', 'rentabilidadTotal', 'tasaAnual'])
        && data.resultado.valorFinal is number
        && data.resultado.totalAportado is number
        && data.resultado.ganancia is number
        && data.resultado.rentabilidadTotal is number
        && data.resultado.tasaAnual is number
        && data.createdAt == request.time; // debe ser serverTimestamp()
    }

    // ─── Reglas por colección ────────────────────────────────────────────────

    match /users/{userId} {

      // El documento raíz del usuario no se lee ni escribe directamente
      allow read, write: if false;

      // Subcolección: data (profile y portfolio)
      match /data/{document} {
        allow read: if isOwner(userId);

        allow write: if isOwner(userId)
          && (
            (document == 'profile'        && isValidProfile(request.resource.data))
            || (document == 'portfolio'   && isValidAllocation(request.resource.data))
            || (document == 'onboarding'  && isValidOnboarding(request.resource.data))
            || (document == 'tradingAccount' && isValidTradingAccount(request.resource.data))
          );

        // Solo se permiten los documentos esperados
        allow create: if isOwner(userId)
          && (document == 'profile' || document == 'portfolio' || document == 'onboarding' || document == 'tradingAccount');
      }

      // Subcolección: simulaciones guardadas
      match /simulations/{simId} {
        allow read:   if isOwner(userId);
        allow create: if isOwner(userId) && isValidSimulation(request.resource.data);
        // Las simulaciones son inmutables, pero el owner puede eliminarlas
        allow update: if false;
        allow delete: if isOwner(userId);
      }

      // Subcolección: historial de trades (Kasane Lab 🧪)
      match /trades/{tradeId} {
        allow read:   if isOwner(userId);
        allow create: if isOwner(userId) && isValidTradeOrder(request.resource.data);
        // Las órdenes son inmutables una vez registradas
        allow update: if false;
        allow delete: if false;
      }
    }

    // ─── Denegar todo acceso no cubierto arriba ──────────────────────────────
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
